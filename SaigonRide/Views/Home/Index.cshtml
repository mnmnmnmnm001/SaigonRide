@{
    ViewData["Title"] = "SaigonRide - Vehicle Rental System";
}

<div class="text-center">
    <h1 class="display-4">Welcome to SaigonRide</h1>
    <p>Distributed Vehicle Rental System</p>
</div>

<div class="container mt-5">
    <div class="row">
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Total Users</h5>
                    <p class="card-text display-6">@ViewData["TotalUsers"]</p>
                    <a href="/User" class="btn btn-primary">Manage Users</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Total Vehicles</h5>
                    <p class="card-text display-6">@ViewData["TotalVehicles"]</p>
                    <a href="/Vehicle" class="btn btn-primary">Manage Vehicles</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Total Stations</h5>
                    <p class="card-text display-6">@ViewData["TotalStations"]</p>
                    <a href="/Station" class="btn btn-primary">Manage Stations</a>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-3">
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Total Rentals</h5>
                    <p class="card-text display-6">@ViewData["TotalRentals"]</p>
                    <a href="/Rental" class="btn btn-primary">View Rentals</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Total Revenue</h5>
                    <p class="card-text display-6">@string.Format("{0:N0}", ViewData["TotalRevenue"]) VND</p>
                    <a href="/Report/RevenueReport" class="btn btn-primary">View Report</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">System Status</h5>
                    <p class="card-text"><span class="badge bg-success">Active</span></p>
                    <a href="/Report/InventoryReport" class="btn btn-primary">Inventory Report</a>
                </div>
            </div>
        </div>
    </div>
</div>
