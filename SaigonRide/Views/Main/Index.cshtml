@inject SaigonRide.Services.ILocalizationService Loc
@{
    ViewData["Title"] = "Main - SaigonRide";
    var lang = Context.Session.GetString("Lang") ?? "en";
}

<div class="position-relative" style="height: 100vh; display: flex; flex-direction: column;">
    <!-- Main Content -->
    <div class="flex-grow-1 d-flex align-items-center justify-content-center">
        <div class="text-center">
            <h1 class="display-3 mb-4">SaigonRide Kiosk</h1>
            <div class="btn-group btn-group-lg">
                <a class="btn btn-primary btn-lg me-3" asp-action="Rent">
                    <i class="bi bi-bicycle"></i> @(lang == "vn" ? "Thuê Xe" : "Rent Vehicle")
                </a>
                <a class="btn btn-secondary btn-lg" asp-action="Return">
                    <i class="bi bi-arrow-counterclockwise"></i> @(lang == "vn" ? "Trả Xe" : "Return Vehicle")
                </a>
            </div>
        </div>
    </div>

    <!-- Admin Panel at Bottom Right -->
    <div style="position: fixed; bottom: 20px; right: 20px;">
        @{
            var isLoggedIn = !string.IsNullOrEmpty(Context.Session.GetString("AdminUsername"));
        }

        @if (isLoggedIn)
        {
            <div class="btn-group-vertical" style="width: 140px;">
                <a href="/Home/Index" class="btn btn-success btn-sm">📊 Dashboard</a>
                <a href="/Admin/Logout" class="btn btn-danger btn-sm">🚪 Logout</a>
            </div>
        }
        else
        {
            <a href="/Admin/Login" class="btn btn-dark btn-lg" style="font-size: 1rem; padding: 10px 20px;">
                🔐 Login as Admin
            </a>
        }
    </div>
</div>

<style>
    body {
        margin: 0;
        padding: 0;
        overflow: hidden;
    }
</style>
