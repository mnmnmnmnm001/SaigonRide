@model List<SaigonRide.Models.Vehicle>
@{
    ViewData["Title"] = "Rent Vehicle";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h2 class="card-title mb-0">Available Vehicles</h2>
                </div>
                <div class="card-body">
                    @if (Model.Count == 0)
                    {
                        <div class="alert alert-info" role="alert">
                            <strong>No vehicles available at the moment.</strong> Please check back later.
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover vehicle-table">
                                <thead>
                                    <tr>
                                        <th>Code</th>
                                        <th>Type</th>
                                        <th>Fare Per Minute</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach(var v in Model)
                                    {
                                        <tr>
                                            <td><strong>@v.Code</strong></td>
                                            <td>@v.Type</td>
                                            <td>@v.FarePerMin VND</td>
                                            <td><a class="btn btn-sm btn-primary" asp-action="RentDetails" asp-route-id="@v.Code">Rent Now</a></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }

                    <div class="mt-4">
                        <a asp-action="Index" class="btn btn-secondary">Back to Home</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .vehicle-table {
        margin-bottom: 0;
    }

    .vehicle-table thead {
        background-color: #f8f9fa;
    }

    html[data-theme="dark"] .vehicle-table {
        color: var(--text-primary);
    }

    html[data-theme="dark"] .vehicle-table thead {
        background-color: var(--bg-secondary);
    }

    html[data-theme="dark"] .vehicle-table tbody tr {
        background-color: #5a3f8a;
        border-bottom-color: var(--border-color);
        color: #e0e0e0;
    }

    html[data-theme="dark"] .vehicle-table tbody tr td {
        border-color: #6a4f9a;
    }

    html[data-theme="dark"] .vehicle-table tbody tr td strong {
        color: #ffffff;
    }

    html[data-theme="dark"] .vehicle-table tbody tr:hover {
        background-color: #7a5fba;
        color: white;
    }

    html[data-theme="dark"] .vehicle-table tbody tr:hover td {
        color: white;
        border-color: #8a6fca;
    }

    html[data-theme="dark"] .vehicle-table tbody tr:hover strong {
        color: #ffffff;
    }

    html[data-theme="dark"] .vehicle-table tbody tr:hover .btn-primary {
        background-color: #ffffff;
        color: #7a5fba;
        border-color: #ffffff;
    }

    html[data-theme="dark"] .vehicle-table tbody tr:hover strong {
        color: white;
    }

    html[data-theme="dark"] .vehicle-table tbody tr:hover .btn-primary {
        background-color: #ffffff;
        color: #6f42c1;
        border-color: #ffffff;
    }
</style>
