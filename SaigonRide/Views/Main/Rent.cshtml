@model List<SaigonRide.Models.Station>
@inject SaigonRide.Services.ILocalizationService Loc
@{
    ViewData["Title"] = "Select Station";
    var allVehicles = ViewData["AllAvailableVehicles"] as List<SaigonRide.Models.Vehicle> ?? new List<SaigonRide.Models.Vehicle>();
    var lang = Context.Session.GetString("Lang") ?? "en";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header py-3">
                    <h2 class="card-title mb-0"><i class="bi bi-geo-alt-fill me-2 text-primary"></i>@Loc.Get("FindStation", lang)</h2>
                    <p class="text-muted mb-0">@Loc.Get("SelectStationDesc", lang)</p>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover vehicle-table align-middle mb-0">
                            <thead>
                                <tr>
                                    <th class="ps-4">@Loc.Get("StationName", lang)</th>
                                    <th class="text-center">@Loc.Get("Bikes", lang)</th>
                                    <th class="text-center">@Loc.Get("EBikes", lang)</th>
                                    <th class="text-center">@Loc.Get("Scooters", lang)</th>
                                    <th class="text-center">@Loc.Get("Capacity", lang)</th>
                                    <th class="text-center">@Loc.Get("Action", lang)</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var station in Model)
                                {
                                    var bikesAtStation = allVehicles.Count(v => v.CurrentPos == station.Name && v.Type == "StandardBike");
                                    var eBikesAtStation = allVehicles.Count(v => v.CurrentPos == station.Name && v.Type == "EBike");
                                    var scootersAtStation = allVehicles.Count(v => v.CurrentPos == station.Name && v.Type == "Scooter");
                                    var totalVehicles = bikesAtStation + eBikesAtStation + scootersAtStation;

                                    <tr>
                                        <td class="ps-4">
                                            <div class="fw-bold text-primary h5 mb-0">@Loc.GetStationName(station.Name, lang)</div>
                                        </td>
                                        <td class="text-center">
                                            <span class="badge @(bikesAtStation > 0 ? "bg-success" : "bg-secondary") rounded-pill">
                                                @bikesAtStation
                                            </span>
                                        </td>
                                        <td class="text-center">
                                            <span class="badge @(eBikesAtStation > 0 ? "bg-warning text-dark" : "bg-secondary") rounded-pill">
                                                @eBikesAtStation
                                            </span>
                                        </td>
                                        <td class="text-center">
                                            <span class="badge @(scootersAtStation > 0 ? "bg-info text-dark" : "bg-secondary") rounded-pill">
                                                @scootersAtStation
                                            </span>
                                        </td>
                                        <td class="text-center">
                                            <div class="progress mb-1" style="height: 8px; width: 100px; margin: 0 auto; background-color: rgba(255,255,255,0.1);">
                                                <div class="progress-bar bg-info" role="progressbar" 
                                                     style="width: @(station.MaxCapacity > 0 ? (station.CurrentCapacity * 100 / station.MaxCapacity) : 0)%" 
                                                     aria-valuenow="@station.CurrentCapacity" aria-valuemin="0" aria-valuemax="@station.MaxCapacity"></div>
                                            </div>
                                            <small class="text-muted" style="font-size: 0.75rem;">
                                                @(station.MaxCapacity - station.CurrentCapacity) @Loc.Get("SlotsFree", lang)
                                            </small>
                                        </td>
                                        <td class="text-center">
                                            <a asp-action="SelectVehicle" asp-route-stationId="@station.StationId" 
                                               class="btn btn-sm btn-outline-primary rounded-pill px-3 @(totalVehicles == 0 ? "disabled" : "")">
                                                @Loc.Get("ViewVehicles", lang) <i class="bi bi-chevron-right ms-1"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            
            <div class="mt-4 text-center">
                <a asp-action="Index" class="btn btn-link text-decoration-none">
                    <i class="bi bi-house-door me-1"></i> @Loc.Get("BackToDashboard", lang)
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    .vehicle-table thead {
        background-color: var(--bg-secondary);
        border-top: 1px solid var(--border-color);
    }
    
    .vehicle-table tr {
        transition: all 0.2s ease;
    }
    
    .vehicle-table tbody tr:hover {
        background-color: rgba(13, 110, 253, 0.05) !important;
        transform: scale(1.002);
    }

    .badge {
        min-width: 2.5rem;
    }
</style>
