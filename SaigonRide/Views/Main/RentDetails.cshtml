@model SaigonRide.Models.Vehicle
@{
    ViewData["Title"] = "Rent Vehicle";
    var stations = ViewData["Stations"] as List<SaigonRide.Models.Station>;
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card">
                <div class="card-header">
                    <h2 class="card-title mb-0">Rent @Model.Code</h2>
                </div>
                <div class="card-body">
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <strong>Error!</strong> @TempData["Error"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <form asp-action="ProcessRent" method="post" id="rentForm" novalidate>
                        <input type="hidden" name="vehicleId" value="@Model.Code" />

                        <div class="mb-3">
                            <label for="stationId" class="form-label">Start Station <span class="text-danger">*</span></label>
                            <input type="hidden" name="stationId" value="@ViewData["SelectedStationId"]" />
                            <select id="stationId" class="form-control" disabled>
                                <option value="">-- Select a Station --</option>
                                @foreach(var s in stations)
                                {
                                    if (ViewData["SelectedStationId"] != null && s.StationId == (int)ViewData["SelectedStationId"])
                                    {
                                        <option value="@s.StationId" selected>@s.Name (@s.CurrentCapacity/@s.MaxCapacity)</option>
                                    }
                                    else
                                    {
                                        <option value="@s.StationId">@s.Name (@s.CurrentCapacity/@s.MaxCapacity)</option>
                                    }
                                }
                            </select>
                            <div class="invalid-feedback">
                                Please select a valid station.
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="userType" class="form-label">User Type <span class="text-danger">*</span></label>
                            <select id="userType" name="userType" class="form-control" required>
                                <option value="">-- Select User Type --</option>
                                <option value="LocalCommuter">Local Commuter</option>
                                <option value="ForeignTourist">Foreign Tourist</option>
                            </select>
                            <div class="invalid-feedback">
                                Please select a user type.
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="bankNum" class="form-label">Bank Number <span class="text-danger">*</span></label>
                            <input type="text" name="bankNum" id="bankNum" class="form-control" placeholder="Enter your bank number" required />
                            <div class="invalid-feedback">
                                Bank number is required.
                            </div>
                        </div>

                        <div class="mb-3" id="passportField" style="display: none;">
                            <label for="passport" class="form-label">Passport Number <span class="text-danger">*</span></label>
                            <input type="text" name="passport" id="passport" class="form-control" placeholder="Enter your passport number" />
                            <div class="invalid-feedback">
                                Passport number is required for foreign tourists.
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="minutes" class="form-label">Rental Duration (Minutes) <span class="text-danger">*</span></label>
                            <input type="number" name="minutes" id="minutes" class="form-control" value="30" min="1" max="1440" required />
                            <small class="form-text text-muted">Between 1 and 1440 minutes (24 hours)</small>
                            <div class="invalid-feedback">
                                Rental duration must be between 1 and 1440 minutes.
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="paymentMethod" class="form-label">Payment Method <span class="text-danger">*</span></label>
                            <select id="paymentMethod" name="paymentMethod" class="form-control" required>
                                <option value="" selected disabled>-- Select Payment Method --</option>
                            </select>
                            <div class="invalid-feedback">
                                Please select a payment method.
                            </div>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <button class="btn btn-primary" type="submit">Confirm Rent</button>
                            <a asp-action="Rent" class="btn btn-secondary">Back</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Form validation
    const form = document.getElementById('rentForm');
    const userTypeSelect = document.getElementById('userType');
    const paymentMethodSelect = document.getElementById('paymentMethod');
    const passportField = document.getElementById('passportField');
    const passportInput = document.getElementById('passport');

    // Handle user type change
    function updatePaymentMethods() {
        const userType = userTypeSelect.value;
        paymentMethodSelect.innerHTML = '<option value="" disabled>-- Select Payment Method --</option>';

        if (userType === 'LocalCommuter') {
            passportField.style.display = 'none';
            passportInput.removeAttribute('required');
            paymentMethodSelect.innerHTML += '<option value="Cash">Cash</option>';
            paymentMethodSelect.innerHTML += '<option value="MoMo">MoMo</option>';
            paymentMethodSelect.innerHTML += '<option value="VNPay">VNPay</option>';
        } else if (userType === 'ForeignTourist') {
            passportField.style.display = 'block';
            passportInput.setAttribute('required', 'required');
            paymentMethodSelect.innerHTML += '<option value="Cash">Cash</option>';
            paymentMethodSelect.innerHTML += '<option value="ApplePay">ApplePay</option>';
            paymentMethodSelect.innerHTML += '<option value="PayPal">PayPal</option>';
        }
    }

    userTypeSelect.addEventListener('change', updatePaymentMethods);

    // Form submit validation
    form.addEventListener('submit', function(event) {
        if (!form.checkValidity() === false) {
            event.preventDefault();
            event.stopPropagation();
        }
        form.classList.add('was-validated');
    }, false);

    // Validate minutes input
    const minutesInput = document.getElementById('minutes');
    minutesInput.addEventListener('change', function() {
        const value = parseInt(this.value);
        if (isNaN(value) || value < 1 || value > 1440) {
            this.classList.add('is-invalid');
        } else {
            this.classList.remove('is-invalid');
        }
    });

    // Initialize on page load
    updatePaymentMethods();
</script>
