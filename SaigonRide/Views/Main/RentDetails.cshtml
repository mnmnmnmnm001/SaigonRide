@model SaigonRide.Models.Vehicle
@inject SaigonRide.Services.ILocalizationService Loc
@{
    ViewData["Title"] = "Rent Vehicle";
    var stations = ViewData["Stations"] as List<SaigonRide.Models.Station>;
    var lang = Context.Session.GetString("Lang") ?? "en";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card">
                <div class="card-header">
                    <h2 class="card-title mb-0">@Loc.Get("Rent", lang) @Model.Code</h2>
                </div>
                <div class="card-body">
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <strong>Error!</strong> @TempData["Error"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <form asp-action="ProcessRent" method="post" id="rentForm" novalidate>
                        <input type="hidden" name="vehicleId" value="@Model.Code" />

                        <div class="mb-3">
                            <label class="form-label">@Loc.Get("StartStation", lang) <span class="text-danger">*</span></label>
                            <input type="hidden" name="stationId" value="@ViewData["SelectedStationId"]" />
                            @{
                                var selectedStationName = "";
                                if (ViewData["SelectedStationId"] != null && stations != null) {
                                    var s = stations.FirstOrDefault(x => x.StationId == (int)ViewData["SelectedStationId"]);
                                    if (s != null) {
                                        selectedStationName = Loc.GetStationName(s.Name, lang) + $" ({s.CurrentCapacity}/{s.MaxCapacity})";
                                    }
                                }
                            }
                            <input type="text" class="form-control" value="@selectedStationName" readonly style="background-color: var(--bg-secondary); color: var(--text-color); cursor: not-allowed;" />
                        </div>

                        <div class="mb-3">
                            <label for="userType" class="form-label">@Loc.Get("UserType", lang) <span class="text-danger">*</span></label>
                            <select id="userType" name="userType" class="form-control" required>
                                <option value="">@Loc.Get("SelectUserType", lang)</option>
                                <option value="LocalCommuter">@Loc.Get("LocalCommuter", lang)</option>
                                <option value="ForeignTourist">@Loc.Get("ForeignTourist", lang)</option>
                            </select>
                            <div class="invalid-feedback">
                                Please select a user type.
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="bankNum" class="form-label">@Loc.Get("BankNumber", lang) <span class="text-danger">*</span></label>
                            <input type="text" name="bankNum" id="bankNum" class="form-control" required />
                            <div class="invalid-feedback">
                                Bank number is required.
                            </div>
                        </div>

                        <div class="mb-3" id="passportField" style="display: none;">
                            <label for="passport" class="form-label">@Loc.Get("Passport", lang) <span class="text-danger">*</span></label>
                            <input type="text" name="passport" id="passport" class="form-control" />
                            <div class="invalid-feedback">
                                Passport number is required.
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="minutes" class="form-label">@Loc.Get("RentalDuration", lang) <span class="text-danger">*</span></label>
                            <input type="number" name="minutes" id="minutes" class="form-control" value="30" min="1" max="1440" required />
                            <small class="form-text text-muted">Between 1 and 1440 minutes (24 hours)</small>
                            <div class="invalid-feedback">
                                Rental duration must be between 1 and 1440 minutes.
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="paymentMethod" class="form-label">@Loc.Get("PaymentMethod", lang) <span class="text-danger">*</span></label>
                            <select id="paymentMethod" name="paymentMethod" class="form-control" required>
                                <option value="" selected disabled>@Loc.Get("SelectPaymentMethod", lang)</option>
                            </select>
                            <div class="invalid-feedback">
                                Please select a payment method.
                            </div>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <button class="btn btn-primary" type="submit">@Loc.Get("ConfirmRent", lang)</button>
                            <a asp-action="Rent" class="btn btn-secondary">@Loc.Get("Back", lang)</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Form validation
    const form = document.getElementById('rentForm');
    const userTypeSelect = document.getElementById('userType');
    const paymentMethodSelect = document.getElementById('paymentMethod');
    const passportField = document.getElementById('passportField');
    const passportInput = document.getElementById('passport');

    // Handle user type change
    function updatePaymentMethods() {
        const userType = userTypeSelect.value;
        const textSelectPayment = '@Loc.Get("SelectPaymentMethod", lang)';
        const textCash = '@Loc.Get("Cash", lang)';

        paymentMethodSelect.innerHTML = '<option value="" disabled>' + textSelectPayment + '</option>';

        if (userType === 'LocalCommuter') {
            passportField.style.display = 'none';
            passportInput.removeAttribute('required');
            paymentMethodSelect.innerHTML += '<option value="Cash">' + textCash + '</option>';
            paymentMethodSelect.innerHTML += '<option value="MoMo">MoMo</option>';
            paymentMethodSelect.innerHTML += '<option value="VNPay">VNPay</option>';
        } else if (userType === 'ForeignTourist') {
            passportField.style.display = 'block';
            passportInput.setAttribute('required', 'required');
            paymentMethodSelect.innerHTML += '<option value="Cash">' + textCash + '</option>';
            paymentMethodSelect.innerHTML += '<option value="ApplePay">Apple Pay</option>';
            paymentMethodSelect.innerHTML += '<option value="PayPal">PayPal</option>';
        }
    }

    userTypeSelect.addEventListener('change', updatePaymentMethods);

    // Form submit validation
    form.addEventListener('submit', function(event) {
        if (!form.checkValidity()) {
            event.preventDefault();
            event.stopPropagation();
        }
        form.classList.add('was-validated');
    }, false);

    // Validate minutes input
    const minutesInput = document.getElementById('minutes');
    minutesInput.addEventListener('change', function() {
        const value = parseInt(this.value);
        if (isNaN(value) || value < 1 || value > 1440) {
            this.classList.add('is-invalid');
        } else {
            this.classList.remove('is-invalid');
        }
    });

    // Initialize on page load
    updatePaymentMethods();
</script>
