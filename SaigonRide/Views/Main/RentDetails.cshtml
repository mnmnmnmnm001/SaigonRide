@model SaigonRide.Models.Vehicle
@{
    ViewData["Title"] = "Rent Vehicle";
    var stations = ViewData["Stations"] as List<SaigonRide.Models.Station>;
}

<h1>Rent @Model.Code</h1>
<form asp-action="ProcessRent" method="post">
    <input type="hidden" name="vehicleId" value="@Model.Code" />
    <div class="mb-3">
        <label>Start Station</label>
        <select name="stationId" class="form-control">
            @foreach(var s in stations)
            {
                <option value="@s.StationId">@s.Name (@s.CurrentCapacity/@s.MaxCapacity)</option>
            }
        </select>
    </div>
    <div class="mb-3">
        <label>User Type</label>
        <select id="userType" name="userType" class="form-control">
            <option value="LocalCommuter">Local</option>
            <option value="ForeignTourist">Foreign</option>
        </select>
    </div>
    <div class="mb-3">
        <label>Bank Number</label>
        <input name="bankNum" class="form-control" />
    </div>
    <div class="mb-3">
        <label>Passport (if foreign)</label>
        <input name="passport" class="form-control" />
    </div>
    <div class="mb-3">
        <label>Minutes</label>
        <input type="number" name="minutes" class="form-control" value="30" />
    </div>
    <div class="mb-3">
        <label>Payment Method</label>
        <select id="paymentMethod" name="paymentMethod" class="form-control">
            <option value="">-- Select Payment Method --</option>
        </select>
    </div>
    <button class="btn btn-primary" type="submit">Confirm Rent</button>
    <a asp-action="Rent" class="btn btn-secondary">Back</a>
</form>

<script>
    document.getElementById('userType').addEventListener('change', function() {
        var userType = this.value;
        var paymentSelect = document.getElementById('paymentMethod');
        paymentSelect.innerHTML = '<option value="">-- Select Payment Method --</option>';

        if (userType === 'LocalCommuter') {
            paymentSelect.innerHTML += '<option value="Cash">Cash</option>';
            paymentSelect.innerHTML += '<option value="MoMo">MoMo</option>';
            paymentSelect.innerHTML += '<option value="VNPay">VNPay</option>';
        } else if (userType === 'ForeignTourist') {
            paymentSelect.innerHTML += '<option value="Cash">Cash</option>';
            paymentSelect.innerHTML += '<option value="ApplePay">ApplePay</option>';
            paymentSelect.innerHTML += '<option value="PayPal">PayPal</option>';
        }
    });

    // Trigger change on page load
    document.getElementById('userType').dispatchEvent(new Event('change'));
</script>

<div class="mt-4">
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger" role="alert">
            @TempData["Error"]
        </div>
    }

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
</div>
