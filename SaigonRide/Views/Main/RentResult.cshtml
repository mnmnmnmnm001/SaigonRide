@{
    ViewData["Title"] = "Rent Result";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card border-success">
                <div class="card-header bg-success text-white">
                    <h2 class="card-title mb-0">✓ Rental Started Successfully</h2>
                </div>
                <div class="card-body">
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <h4 class="alert-heading">Success!</h4>
                        <p>Your vehicle rental has been confirmed. The system will automatically return to main screen in <strong><span id="countdown">7</span></strong> seconds.</p>
                    </div>

                    <div class="row mt-4">
                        <div class="col-md-6">
                            <div class="info-box">
                                <h5 class="text-muted">Vehicle Code</h5>
                                <h3 class="text-primary">@ViewData["VehicleCode"]</h3>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="info-box">
                                <h5 class="text-muted">Rental Duration</h5>
                                <h3 class="text-primary">@ViewData["Minutes"] minutes</h3>
                            </div>
                        </div>
                    </div>

                    <div class="row mt-3">
                        <div class="col-md-6">
                            <div class="info-box">
                                <h5 class="text-muted">Amount Charged</h5>
                                <h3 class="text-info">@ViewData["MoneyRented"] VND</h3>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="info-box">
                                <h5 class="text-muted">Status</h5>
                                <h3 class="text-success">✓ Active</h3>
                            </div>
                        </div>
                    </div>

                    <div class="mt-5 text-center">
                        <a asp-action="Index" class="btn btn-primary btn-lg">Return to Home Now</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .info-box {
        padding: 1.5rem;
        background-color: #f8f9fa;
        border-radius: 8px;
        text-align: center;
    }

    html[data-theme="dark"] .info-box {
        background-color: #3d3d3d;
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        let secondsLeft = 7;
        const countdownElement = document.getElementById('countdown');

        if (countdownElement) {
            const countdownInterval = setInterval(function() {
                secondsLeft--;
                if (countdownElement) {
                    countdownElement.textContent = secondsLeft;
                }

                if (secondsLeft <= 0) {
                    clearInterval(countdownInterval);
                    window.location.href = '/Main';
                }
            }, 1000);

            // Backup redirect after 7.1 seconds
            setTimeout(function() {
                window.location.href = '/Main';
            }, 7100);
        }
    });
</script>
