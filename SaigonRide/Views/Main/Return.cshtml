@{
    ViewData["Title"] = "Return Vehicle";
    var stations = ViewBag.Stations as List<SaigonRide.Models.Station> ?? new List<SaigonRide.Models.Station>();
    var vehicles = ViewBag.Vehicles as List<SaigonRide.Models.Vehicle> ?? new List<SaigonRide.Models.Vehicle>();
}

<h1>Return Vehicle</h1>
<form asp-action="ProcessReturn" method="post">
    <div class="mb-3">
        <label>Vehicle Code</label>
        <select name="vehicleCode" class="form-control">
            <option value="">-- Select a Vehicle in Transit --</option>
            @foreach(var v in vehicles)
            {
                <option value="@v.Code">@v.Code - @v.Type (@v.CurrentPos)</option>
            }
        </select>
    </div>
    <div class="mb-3">
        <label>Return Station</label>
        <select name="returnStationId" class="form-control">
            @foreach(var s in stations)
            {
                <option value="@s.StationId">@s.Name (@s.CurrentCapacity/@s.MaxCapacity)</option>
            }
        </select>
    </div>
    <button class="btn btn-primary" type="submit">Return</button>
</form>

<div class="mt-4">
    @if (ViewData.ModelState != null && ViewData.ModelState.Values.SelectMany(v => v.Errors).Any())
    {
        <div class="alert alert-danger">
            <ul>
                @foreach (var e in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <li>@e.ErrorMessage</li>
                }
            </ul>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }
</div>
