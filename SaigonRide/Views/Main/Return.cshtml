@inject SaigonRide.Services.ILocalizationService Loc
@{
    ViewData["Title"] = "Return Vehicle";
    var stations = ViewBag.Stations as List<SaigonRide.Models.Station> ?? new List<SaigonRide.Models.Station>();
    var vehicles = ViewBag.Vehicles as List<SaigonRide.Models.Vehicle> ?? new List<SaigonRide.Models.Vehicle>();
    var lang = Context.Session.GetString("Lang") ?? "en";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card">
                <div class="card-header">
                    <h2 class="card-title mb-0">@Loc.Get("ReturnVehicle", lang)</h2>
                </div>
                <div class="card-body">
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <strong>Error!</strong> @TempData["Error"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    @if (ViewData.ModelState != null && ViewData.ModelState.Values.SelectMany(v => v.Errors).Any())
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <strong>Validation Errors:</strong>
                            <ul class="mb-0">
                                @foreach (var e in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                                {
                                    <li>@e.ErrorMessage</li>
                                }
                            </ul>
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <form asp-action="ProcessReturn" method="post" id="returnForm" novalidate>
                        <div class="mb-3">
                            <label for="vehicleCode" class="form-label">@Loc.Get("VehicleCode", lang) <span class="text-danger">*</span></label>
                            <select name="vehicleCode" id="vehicleCode" class="form-control" required>
                                <option value="">@Loc.Get("Select Vehicle In Transit", lang)</option>
                                @foreach(var v in vehicles)
                                {
                                    <option value="@v.Code" data-type="@v.Type">@v.Code - @Loc.Get(v.Type ?? "", lang) (@Loc.Get("InTransit", lang))</option>
                                }
                            </select>
                            <div class="invalid-feedback">
                                @Loc.Get("Please Select Vehicle", lang)
                            </div>
                            <div id="timeUsedContainer" style="display:none;" class="mt-2 text-info fw-bold">
                                <strong>@Loc.Get("Time Used", lang):</strong> <span id="timeUsedDisplay"></span>
                            </div>
                            @if (vehicles.Count == 0)
                            {
                                <small class="form-text text-muted d-block mt-2">@Loc.Get("No Vehicles In Transit", lang)</small>
                            }
                        </div>

                        <div class="mb-3">
                            <label for="returnStationId" class="form-label">@Loc.Get("Return Station", lang) <span class="text-danger">*</span></label>
                            <select name="returnStationId" id="returnStationId" class="form-control" required>
                                <option value="">@Loc.Get("Select Return Station", lang)</option>
                                @foreach(var s in stations)
                                {
                                    var capacityPercent = (s.CurrentCapacity * 100) / (s.MaxCapacity > 0 ? s.MaxCapacity : 1);
                                    <option value="@s.StationId" data-capacity="@s.CurrentCapacity" data-max-capacity="@s.MaxCapacity">
                                        @Loc.GetStationName(s.Name ?? "", lang) (@s.CurrentCapacity/@s.MaxCapacity) @(capacityPercent >= 90 ? Loc.Get("AlmostFull", lang) : "")
                                    </option>
                                }
                            </select>
                            <div class="invalid-feedback">
                                @Loc.Get("Please Select Return Station", lang)
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="paymentMethod" class="form-label">@Loc.Get("PaymentMethod", lang) <span class="text-danger">*</span></label>
                            <select id="paymentMethod" name="paymentMethod" class="form-control" required>
                                <option value="" selected disabled>@Loc.Get("Select Payment Method", lang)</option>
                            </select>
                            <div class="invalid-feedback">
                                Please select a payment method.
                            </div>
                        </div>

                        <div id="qrCodeContainer" class="mb-3 text-center" style="display: none;">
                            <div class="p-3 border rounded bg-light d-inline-block">
                                <img id="qrCodeImage" src="" alt="VietQR" class="img-fluid" style="max-height: 350px;" />
                                <p class="mt-2 mb-0 text-muted fw-bold">@Loc.Get("ScanQRPay", lang) <span id="qrAmountDisplay" class="text-primary"></span> VND</p>
                            </div>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <button class="btn btn-primary" type="submit" id="submitBtn">@Loc.Get("Return Vehicle", lang)</button>
                            <a asp-action="Index" asp-controller="Main" class="btn btn-secondary">@Loc.Get("Back", lang)</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    const form = document.getElementById('returnForm');
    const vehicleSelect = document.getElementById('vehicleCode');
    const stationSelect = document.getElementById('returnStationId');
    const submitBtn = document.getElementById('submitBtn');
    const paymentMethodSelect = document.getElementById('paymentMethod');

    const startTimes = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.StartTimes ?? new Dictionary<string, string>()));
    const userTypes = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.UserTypes ?? new Dictionary<string, string>()));
    let timeInterval;

    function updatePaymentMethods() {
        const selectedVehicle = vehicleSelect.value;
        const textSelectPayment = '@Loc.Get("SelectPaymentMethod", lang)';
        const textCash = '@Loc.Get("Cash", lang)';
        
        paymentMethodSelect.innerHTML = '<option value="" disabled selected>' + textSelectPayment + '</option>';
        document.getElementById('qrCodeContainer').style.display = 'none';
        
        if (selectedVehicle && userTypes[selectedVehicle]) {
            let uType = userTypes[selectedVehicle];
            if (uType !== 'ForeignTourist') uType = 'LocalCommuter'; // Default for old rentals

            if (uType === 'LocalCommuter') {
                paymentMethodSelect.innerHTML += '<option value="Cash">' + textCash + '</option>';
                paymentMethodSelect.innerHTML += '<option value="MoMo">MoMo</option>';
                paymentMethodSelect.innerHTML += '<option value="VNPay">VNPay</option>';
            } else if (uType === 'ForeignTourist') {
                paymentMethodSelect.innerHTML += '<option value="Cash">' + textCash + '</option>';
                paymentMethodSelect.innerHTML += '<option value="ApplePay">Apple Pay</option>';
                paymentMethodSelect.innerHTML += '<option value="PayPal">PayPal</option>';
            }
        }
    }

    paymentMethodSelect.addEventListener('change', function() {
        const qrContainer = document.getElementById('qrCodeContainer');
        if (this.value && this.value !== 'Cash') {
            qrContainer.style.display = 'block';
            updateQrCode();
        } else {
            qrContainer.style.display = 'none';
        }
    });

    function updateQrCode() {
        const selectedVehicle = vehicleSelect.value;
        const selectedStation = stationSelect.value;
        const paymentMethod = paymentMethodSelect.value;
        
        if (!selectedVehicle || !paymentMethod || paymentMethod === 'Cash' || !startTimes[selectedVehicle]) {
            return;
        }

        // Calculate fare
        const vehicleOption = vehicleSelect.options[vehicleSelect.selectedIndex];
        const vType = vehicleOption.getAttribute('data-type');
        let rate = 500;
        if (vType === 'EBike') rate = 1000;
        else if (vType === 'Scooter') rate = 1500;

        const startTime = new Date(startTimes[selectedVehicle]);
        const now = new Date();
        const diffMs = now - startTime;
        let diffMins = Math.ceil(diffMs / 60000);
        if (diffMins < 1) diffMins = 1;

        let fare = diffMins * rate;

        // Apply discount if low inventory return station
        if (selectedStation) {
            const stationOption = stationSelect.options[stationSelect.selectedIndex];
            const currentCapacity = parseInt(stationOption.getAttribute('data-capacity'));
            const maxCapacity = parseInt(stationOption.getAttribute('data-max-capacity'));
            if (maxCapacity > 0 && (currentCapacity / maxCapacity) < 0.20) {
                fare = fare * 0.85; // 15% discount
            }
        }

        const qrAmountDisplay = document.getElementById('qrAmountDisplay');
        qrAmountDisplay.innerText = Math.round(fare).toLocaleString();

        const accountName = encodeURIComponent("Tran Hoang Khai");
        const addInfo = encodeURIComponent("SaigonRide " + selectedVehicle);
        const qrUrl = `https://img.vietqr.io/image/970423-00001756255-compact2.png?amount=${Math.round(fare)}&addInfo=${addInfo}&accountName=${accountName}`;
        
        const qrImage = document.getElementById('qrCodeImage');
        if (qrImage.src !== qrUrl) {
            qrImage.src = qrUrl;
        }
    }

    function updateTimeUsed() {
        const selectedVehicle = vehicleSelect.value;
        const container = document.getElementById('timeUsedContainer');
        const display = document.getElementById('timeUsedDisplay');
        
        if (selectedVehicle && startTimes[selectedVehicle]) {
            container.style.display = 'block';
            
            if (timeInterval) clearInterval(timeInterval);
            
            const startTime = new Date(startTimes[selectedVehicle]);
            
            const renderTime = () => {
                const now = new Date();
                const diffMs = now - startTime;
                const diffMins = Math.floor(diffMs / 60000);
                const diffSecs = Math.floor((diffMs % 60000) / 1000);
                const hrs = Math.floor(diffMins / 60);
                const mins = diffMins % 60;
                
                let timeStr = "";
                if (hrs > 0) timeStr += hrs + "h ";
                timeStr += mins + "m " + diffSecs + "s";
                
                display.innerText = timeStr;
            };
            
            renderTime();
            updateQrCode();
            timeInterval = setInterval(() => {
                renderTime();
                updateQrCode();
            }, 1000);
        } else {
            container.style.display = 'none';
            if (timeInterval) clearInterval(timeInterval);
        }
    }

    vehicleSelect.addEventListener('change', function() {
        this.classList.remove('is-invalid');
        updateTimeUsed();
        updatePaymentMethods();
    });

    // Form submit validation
    form.addEventListener('submit', function(event) {
        // Check if selections are made
        if (!vehicleSelect.value) {
            event.preventDefault();
            event.stopPropagation();
            vehicleSelect.classList.add('is-invalid');
            showAlert('@Loc.Get("PleaseSelectVehicle", lang)', 'danger');
            return false;
        }

        if (!stationSelect.value) {
            event.preventDefault();
            event.stopPropagation();
            stationSelect.classList.add('is-invalid');
            showAlert('@Loc.Get("PleaseSelectReturnStation", lang)', 'danger');
            return false;
        }

        // Check if station has capacity
        const selectedOption = stationSelect.options[stationSelect.selectedIndex];
        const currentCapacity = parseInt(selectedOption.getAttribute('data-capacity'));
        const maxCapacity = parseInt(selectedOption.getAttribute('data-max-capacity'));

        if (currentCapacity >= maxCapacity) {
            event.preventDefault();
            event.stopPropagation();
            stationSelect.classList.add('is-invalid');
            showAlert('@Loc.Get("StationFullCapacity", lang)', 'danger');
            return false;
        }

        form.classList.add('was-validated');
    }, false);


    stationSelect.addEventListener('change', function() {
        this.classList.remove('is-invalid');
        updateQrCode();
    });

    // Helper function to show alerts
    function showAlert(message, type = 'danger') {
        const alertDiv = document.createElement('div');
        alertDiv.className = `alert alert-${type} alert-dismissible fade show`;
        alertDiv.setAttribute('role', 'alert');
        alertDiv.innerHTML = `
            ${message}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        `;

        const formCard = form.closest('.card-body');
        formCard.insertBefore(alertDiv, form);

        // Auto-dismiss after 5 seconds
        setTimeout(() => {
            alertDiv.remove();
        }, 5000);
    }
</script>
