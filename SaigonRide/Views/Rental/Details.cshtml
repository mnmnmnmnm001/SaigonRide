@model SaigonRide.Models.Rental

@{
    ViewData["Title"] = "Rental Details";
}

<h1>Rental Details</h1>

<div class="container">
    <div class="row">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5>Rental Information</h5>
                </div>
                <div class="card-body">
                    <p><strong>Rental ID:</strong> @Model.RentalId</p>
                    <p><strong>User ID:</strong> @Model.UserId</p>
                    <p><strong>Vehicle:</strong> @Model.Vehicle?.Type (@Model.Vehicle?.Code)</p>
                    <p><strong>Start Station:</strong> @Model.StartStation?.Name</p>
                    <p><strong>End Station:</strong> @Model.EndStation?.Name</p>
                    <p><strong>Start Time:</strong> @Model.TimeStart.ToString("yyyy-MM-dd HH:mm:ss")</p>
                    <p><strong>End Time:</strong> @(Model.TimeEnd != DateTime.MinValue ? Model.TimeEnd.ToString("yyyy-MM-dd HH:mm:ss") : "In Progress")</p>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5>Fare Information</h5>
                </div>
                <div class="card-body">
                    <p><strong>Calculated Fare:</strong> @string.Format("{0:N0}", Model.CalculatedFare) VND</p>
                    <p><strong>Discount Applied:</strong> @string.Format("{0:N0}", Model.DiscountApplied) VND</p>
                    <p><strong>Final Fare:</strong> @string.Format("{0:N0}", Model.FinalFare) VND</p>
                    <p>
                        <strong>Status:</strong>
                        @if (Model.Status == 0)
                        {
                            <span class="badge bg-warning">Active</span>
                        }
                        else if (Model.Status == 1)
                        {
                            <span class="badge bg-success">Completed</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Cancelled</span>
                        }
                    </p>
                </div>
            </div>
        </div>
    </div>
    <div class="mt-3">
        @if (Model.Status == 0)
        {
            <a asp-action="EndRental" asp-route-id="@Model.RentalId" class="btn btn-success">End Rental</a>
        }
        <a asp-action="Index" class="btn btn-secondary">Back to Rentals</a>
    </div>
</div>
