@model IEnumerable<SaigonRide.Services.StationInventoryReport>
@inject SaigonRide.Services.ILocalizationService Loc

@{
    ViewData["Title"] = "Inventory Report";
    var lang = Context.Session.GetString("Lang") ?? "en";
}

<h1>@Loc.Get("Station Inventory Utilization Report", lang)</h1>

@if (Model != null && Model.Any())
{
    <div class="row">
        @foreach (var station in Model)
        {
            <div class="col-md-6 mb-3">
                <div class="card">
                    <div class="card-header">
                        <h5>@Loc.GetStationName(station.StationName ?? "", lang)</h5>
                    </div>
                    <div class="card-body">
                        <dl class="row">
                            <dt class="col-sm-4">@Loc.Get("ID", lang)</dt>
                            <dd class="col-sm-8">@station.StationId</dd>

                            <dt class="col-sm-4">@Loc.Get("Current Max Capacity", lang)</dt>
                            <dd class="col-sm-8">@station.CurrentCapacity / @station.MaxCapacity</dd>

                            <dt class="col-sm-4">@Loc.Get("Utilization Ratio", lang)</dt>
                            <dd class="col-sm-8">@string.Format("{0:P2}", station.UtilizationRatio)</dd>

                            <dt class="col-sm-4">@Loc.Get("Status", lang)</dt>
                            <dd class="col-sm-8">
                                @if (station.Status == "Low")
                                {
                                    <span class="badge bg-danger" style="font-size: 1rem;">@Loc.Get("Low Inventory", lang)</span>
                                }
                                else if (station.Status == "Medium")
                                {
                                    <span class="badge bg-warning" style="font-size: 1rem;">@Loc.Get("Medium", lang)</span>
                                }
                                else
                                {
                                    <span class="badge bg-success" style="font-size: 1rem;">@Loc.Get("High", lang)</span>
                                }
                            </dd>
                        </dl>

                        <div class="mt-3">
                            <h6>@Loc.Get("Capacity Visualization", lang)</h6>
                            <div class="progress" style="height: 30px;">
                                <div class="progress-bar" role="progressbar" style="width: @string.Format("{0:P0}", station.UtilizationRatio)" aria-valuenow="@station.CurrentCapacity" aria-valuemin="0" aria-valuemax="@station.MaxCapacity">
                                    @string.Format("{0:P0}", station.UtilizationRatio)
                                </div>
                            </div>
                        </div>

                        @if (station.Status == "Low")
                        {
                            <div class="alert alert-warning mt-3">
                                @Loc.Get("Low Inventory Warning", lang)
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="alert alert-info">
        @Loc.Get("NoInventoryData", lang)
    </div>
}

<div class="mt-3">
    <a href="/" class="btn btn-secondary">@Loc.Get("BackToDashboard", lang)</a>
</div>
