@model SaigonRide.Services.StationInventoryReport

@{
    ViewData["Title"] = "Inventory Report";
}

<h1>Station Inventory / Utilization Report</h1>

@if (Model != null)
{
    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <h5>@Model.StationName</h5>
                </div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-3">Station ID</dt>
                        <dd class="col-sm-9">@Model.StationId</dd>

                        <dt class="col-sm-3">Current Capacity</dt>
                        <dd class="col-sm-9">@Model.CurrentCapacity / @Model.MaxCapacity</dd>

                        <dt class="col-sm-3">Utilization Ratio</dt>
                        <dd class="col-sm-9">@string.Format("{0:P2}", Model.UtilizationRatio)</dd>

                        <dt class="col-sm-3">Status</dt>
                        <dd class="col-sm-9">
                            @if (Model.Status == "Low")
                            {
                                <span class="badge bg-danger" style="font-size: 1rem;">Low Inventory</span>
                            }
                            else if (Model.Status == "Medium")
                            {
                                <span class="badge bg-warning" style="font-size: 1rem;">Medium</span>
                            }
                            else
                            {
                                <span class="badge bg-success" style="font-size: 1rem;">High</span>
                            }
                        </dd>
                    </dl>

                    <div class="mt-3">
                        <h6>Capacity Visualization</h6>
                        <div class="progress" style="height: 50px;">
                            <div class="progress-bar" role="progressbar" style="width: @string.Format("{0:P0}", Model.UtilizationRatio)" aria-valuenow="@Model.CurrentCapacity" aria-valuemin="0" aria-valuemax="@Model.MaxCapacity">
                                @string.Format("{0:P0}", Model.UtilizationRatio)
                            </div>
                        </div>
                    </div>

                    @if (Model.Status == "Low")
                    {
                        <div class="alert alert-warning mt-3">
                            <strong>Low Inventory Warning:</strong> This station has less than 20% capacity. Vehicles returned here will receive a 15% discount!
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="alert alert-info">
        No inventory data available.
    </div>
}

<div class="mt-3">
    <a href="/" class="btn btn-secondary">Back to Dashboard</a>
</div>
