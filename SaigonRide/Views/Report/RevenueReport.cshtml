@model IEnumerable<SaigonRide.Services.RevenueByVehicleReport>
@inject SaigonRide.Services.ILocalizationService Loc

@{
    ViewData["Title"] = "Revenue Report";
    var lang = Context.Session.GetString("Lang") ?? "en";
}

<h1>@Loc.Get("RevenueReportByVehicleCategory", lang)</h1>

<div class="row mb-3">
    <div class="col-md-4">
        <form asp-action="RevenueReport" method="get" class="form-inline">
            <div class="form-group mb-2 me-2">
                <label for="startDate" class="me-2">@Loc.Get("StartDate", lang):</label>
                <input type="date" id="startDate" name="startDate" class="form-control" value="@((DateTime)ViewData["StartDate"]).ToString("yyyy-MM-dd")" />
            </div>
            <div class="form-group mb-2 me-2">
                <label for="endDate" class="me-2">@Loc.Get("EndDate", lang):</label>
                <input type="date" id="endDate" name="endDate" class="form-control" value="@((DateTime)ViewData["EndDate"]).ToString("yyyy-MM-dd")" />
            </div>
            <button type="submit" class="btn btn-primary">@Loc.Get("Filter", lang)</button>
        </form>
    </div>
</div>

@if (Model != null && Model.Any())
{
    <div class="row">
        @foreach (var category in Model)
        {
            <div class="col-md-6 mb-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">@Loc.Get(category.VehicleType ?? "", lang)</h5>
                    </div>
                    <div class="card-body">
                        <table class="table table-borderless">
                            <tr>
                                <td class="ps-0"><strong>@Loc.Get("Total Rentals", lang):</strong></td>
                                <td class="text-end pe-0">@category.RentalCount</td>
                            </tr>
                            <tr>
                                <td class="ps-0"><strong>@Loc.Get("Total Revenue", lang):</strong></td>
                                <td class="text-end pe-0">@string.Format("{0:N0}", category.TotalRevenue) VND</td>
                            </tr>
                            <tr>
                                <td class="ps-0"><strong>@Loc.Get("Average Fare", lang):</strong></td>
                                <td class="text-end pe-0">@string.Format("{0:N0}", category.AverageFare) VND</td>
                            </tr>
                            <tr>
                                <td class="ps-0"><strong>@Loc.Get("Total Discount Applied", lang):</strong></td>
                                <td class="text-end pe-0 text-danger">@string.Format("{0:N0}", category.TotalDiscount) VND</td>
                            </tr>
                        </table>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="alert alert-info">
        @Loc.Get("No Rental Data", lang)
        <br/>
        <small>@Loc.Get("Selected Range", lang) @((DateTime?)ViewData["StartDate"])?.ToString("yyyy-MM-dd" ?? Loc.Get("Not Selected", lang)) to @((DateTime?)ViewData["EndDate"])?.ToString("yyyy-MM-dd" ?? Loc.Get("Not Selected", lang))</small>
    </div>
}

<div class="mt-3">
    <a href="/" class="btn btn-secondary">@Loc.Get("Back To Dashboard", lang)</a>
</div>
