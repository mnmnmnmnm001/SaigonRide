@model SaigonRide.Services.RevenueByVehicleReport
@inject SaigonRide.Services.ILocalizationService Loc

@{
    ViewData["Title"] = "Revenue Report";
    var lang = Context.Session.GetString("Lang") ?? "en";
}

<h1>@Loc.Get("RevenueReportByVehicleCategory", lang)</h1>

<div class="row mb-3">
    <div class="col-md-4">
        <form asp-action="RevenueReport" method="get" class="form-inline">
            <div class="form-group mb-2 me-2">
                <label for="startDate" class="me-2">@Loc.Get("StartDate", lang):</label>
                <input type="date" id="startDate" name="startDate" class="form-control" value="@((DateTime)ViewData["StartDate"]).ToString("yyyy-MM-dd")" />
            </div>
            <div class="form-group mb-2 me-2">
                <label for="endDate" class="me-2">@Loc.Get("EndDate", lang):</label>
                <input type="date" id="endDate" name="endDate" class="form-control" value="@((DateTime)ViewData["EndDate"]).ToString("yyyy-MM-dd")" />
            </div>
            <button type="submit" class="btn btn-primary">@Loc.Get("Filter", lang)</button>
        </form>
    </div>
</div>

@if (Model != null && Model.RentalCount > 0)
{
    <div class="card">
        <div class="card-header">
            <h5>@Loc.Get(Model.VehicleType ?? "", lang)</h5>
        </div>
        <div class="card-body">
            <table class="table">
                <tr>
                    <td><strong>@Loc.Get("TotalRentals", lang):</strong></td>
                    <td>@Model.RentalCount</td>
                </tr>
                <tr>
                    <td><strong>@Loc.Get("TotalRevenue", lang):</strong></td>
                    <td>@string.Format("{0:N0}", Model.TotalRevenue) VND</td>
                </tr>
                <tr>
                    <td><strong>@Loc.Get("AverageFare", lang):</strong></td>
                    <td>@string.Format("{0:N0}", Model.AverageFare) VND</td>
                </tr>
                <tr>
                    <td><strong>@Loc.Get("TotalDiscountApplied", lang):</strong></td>
                    <td>@string.Format("{0:N0}", Model.TotalDiscount) VND</td>
                </tr>
            </table>
        </div>
    </div>
}
else
{
    <div class="alert alert-info">
        @Loc.Get("NoRentalData", lang)
        <br/>

        <small>@Loc.Get("SelectedRange", lang) @((DateTime?)ViewData["StartDate"])?.ToString("yyyy-MM-dd" ?? Loc.Get("NotSelected", lang)) to @((DateTime?)ViewData["EndDate"])?.ToString("yyyy-MM-dd" ?? Loc.Get("NotSelected", lang))</small>
        <!--(DateTime?) casts to a nullable DateTime-->
    </div>
}

<div class="mt-3">
    <a href="/" class="btn btn-secondary">@Loc.Get("BackToDashboard", lang)</a>
</div>
