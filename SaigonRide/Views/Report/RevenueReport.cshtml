@model SaigonRide.Services.RevenueByVehicleReport

@{
    ViewData["Title"] = "Revenue Report";
}

<h1>Revenue Report by Vehicle Category</h1>

<div class="row mb-3">
    <div class="col-md-4">
        <form asp-action="RevenueReport" method="get" class="form-inline">
            <div class="form-group mb-2 me-2">
                <label for="startDate" class="me-2">Start Date:</label>
                <input type="date" id="startDate" name="startDate" class="form-control" value="@((DateTime)ViewData["StartDate"]).ToString("yyyy-MM-dd")" />
            </div>
            <div class="form-group mb-2 me-2">
                <label for="endDate" class="me-2">End Date:</label>
                <input type="date" id="endDate" name="endDate" class="form-control" value="@((DateTime)ViewData["EndDate"]).ToString("yyyy-MM-dd")" />
            </div>
            <button type="submit" class="btn btn-primary">Filter</button>
        </form>
    </div>
</div>

@if (Model != null && Model.RentalCount > 0)
{
    <div class="card">
        <div class="card-header">
            <h5>@Model.VehicleType</h5>
        </div>
        <div class="card-body">
            <table class="table">
                <tr>
                    <td><strong>Total Rentals:</strong></td>
                    <td>@Model.RentalCount</td>
                </tr>
                <tr>
                    <td><strong>Total Revenue:</strong></td>
                    <td>@string.Format("{0:N0}", Model.TotalRevenue) VND</td>
                </tr>
                <tr>
                    <td><strong>Average Fare:</strong></td>
                    <td>@string.Format("{0:N0}", Model.AverageFare) VND</td>
                </tr>
                <tr>
                    <td><strong>Total Discount Applied:</strong></td>
                    <td>@string.Format("{0:N0}", Model.TotalDiscount) VND</td>
                </tr>
            </table>
        </div>
    </div>
}
else
{
    <div class="alert alert-info">
        No rental data available for the selected period.
    </div>
}

<div class="mt-3">
    <a href="/" class="btn btn-secondary">Back to Dashboard</a>
</div>
