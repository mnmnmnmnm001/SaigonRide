<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SaigonRide</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SaigonRide.styles.css" asp-append-version="true" />
    <script src="~/js/theme.js" asp-append-version="true"></script>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm border-bottom box-shadow mb-3">
                @{
                    var isAdminLoggedIn = !string.IsNullOrEmpty(Context.Session.GetString("AdminUsername"));
                }
                @if (isAdminLoggedIn)
                {
                    <a class="navbar-brand ms-2 me-4" asp-area="" asp-controller="Home" asp-action="Index">SaigonRide</a>
                }
                else
                {
                    <a class="navbar-brand ms-2 me-4" asp-area="" asp-controller="Main" asp-action="Index">SaigonRide</a>
                }
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        @if (isAdminLoggedIn)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-dark" href="#" id="managementDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    Management
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="managementDropdown">
                                    <li><a class="dropdown-item" asp-area="" asp-controller="User" asp-action="Index">Users</a></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="Vehicle" asp-action="Index">Vehicles</a></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="Station" asp-action="Index">Stations</a></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="Rental" asp-action="Index">Rentals</a></li>
                                </ul>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-dark" href="#" id="reportsDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    Reports
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="reportsDropdown">
                                    <li><a class="dropdown-item" asp-area="" asp-controller="Report" asp-action="RevenueReport">Revenue Report</a></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="Report" asp-action="InventoryReport">Inventory Report</a></li>
                                </ul>
                            </li>
                        }
                    </ul>
                    <ul class="navbar-nav">
                        <li class="nav-item" style="margin-left: 15px;">
                            @{
                                var currentLang = Context.Session.GetString("Lang") ?? "en";
                                var currentUrl = Context.Request.Path + Context.Request.QueryString;
                            }
                            <div class="btn-group" role="group" aria-label="Language toggle">
                                <a href="@Url.Action("SetLanguage", "Main", new { lang = "en", returnUrl = currentUrl })"
                                   class="btn btn-sm btn-outline-secondary @(currentLang == "en" ? "active" : "")">EN</a>
                                <a href="@Url.Action("SetLanguage", "Main", new { lang = "vn", returnUrl = currentUrl })"
                                   class="btn btn-sm btn-outline-secondary @(currentLang == "vn" ? "active" : "")">VN</a>
                            </div>
                        </li>
                        <li class="nav-item">
                            <button id="themeToggleBtn" class="btn btn-sm btn-outline-secondary" onclick="toggleTheme()" style="margin-left: 10px;">
                                <i class="bi bi-moon-fill"></i> Dark
                            </button>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted" style="padding: 0.5rem 0;">
        <div class="container" style="padding: 0.25rem 0;">
            &copy; 2026 - SaigonRide
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
