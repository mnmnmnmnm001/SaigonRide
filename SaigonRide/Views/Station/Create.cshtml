@model SaigonRide.Models.Station

@{
    ViewData["Title"] = "Create Station";
}

<h1>Create New Station</h1>

<div class="row">
    <div class="col-md-6 offset-md-3">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label for="Name" class="form-label">Station Name</label>
                <input type="text" id="Name" name="Name" class="form-control" required />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label for="MaxCapacity" class="form-label">Maximum Capacity</label>
                <input type="number" id="MaxCapacity" name="MaxCapacity" class="form-control" required />
                <span asp-validation-for="MaxCapacity" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label for="CurrentCapacity" class="form-label">Current Capacity</label>
                <input type="number" id="CurrentCapacity" name="CurrentCapacity" class="form-control" required />
                <span asp-validation-for="CurrentCapacity" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">Create Station</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>
