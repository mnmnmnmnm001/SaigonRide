@model SaigonRide.Models.Station
@inject SaigonRide.Services.ILocalizationService Loc

@{
    ViewData["Title"] = "Edit Station";
    var lang = Context.Session.GetString("Lang") ?? "en";
}

<h1>@Loc.Get("EditStation", lang)</h1>

<div class="row">
    <div class="col-md-6 offset-md-3">
        <form asp-action="Edit" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <input type="hidden" name="StationId" value="@Model.StationId" />

            <div class="form-group mb-3">
                <label for="Name" class="form-label">@Loc.Get("StationName", lang)</label>
                <input type="text" id="Name" name="Name" value="@Model.Name" class="form-control" required />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label for="MaxCapacity" class="form-label">@Loc.Get("MaximumCapacity", lang)</label>
                <input type="number" id="MaxCapacity" name="MaxCapacity" value="@Model.MaxCapacity" class="form-control" required />
                <span asp-validation-for="MaxCapacity" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label for="CurrentCapacity" class="form-label">@Loc.Get("CurrentCapacityLabel", lang)</label>
                <input type="number" id="CurrentCapacity" name="CurrentCapacity" value="@Model.CurrentCapacity" class="form-control" required />
                <span asp-validation-for="CurrentCapacity" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">@Loc.Get("UpdateStation", lang)</button>
            <a asp-action="Index" class="btn btn-secondary">@Loc.Get("Cancel", lang)</a>
        </form>
    </div>
</div>
