@model List<SaigonRide.Models.Station>
@inject SaigonRide.Services.ILocalizationService Loc

@{
    ViewData["Title"] = "Station Management";
    var lang = Context.Session.GetString("Lang") ?? "en";
}

<h1>@Loc.Get("StationManagement", lang)</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">@Loc.Get("AddNewStation", lang)</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>@Loc.Get("ID", lang)</th>
            <th>@Loc.Get("Name", lang)</th>
            <th>@Loc.Get("CurrentMaxCapacity", lang)</th>
            <th>@Loc.Get("UtilizationRatio", lang)</th>
            <th>@Loc.Get("Status", lang)</th>
            <th>@Loc.Get("Actions", lang)</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.StationId</td>
                <td>@Loc.GetStationName(item.Name ?? "", lang)</td>
                <td>@item.CurrentCapacity / @item.MaxCapacity</td>
                <td>
                    @{
                        double ratio = item.GetRatio();
                        var statusClass = ratio >= 0.8 ? "success" : (ratio >= 0.5 ? "warning" : "danger");
                    }
                    <span class="badge bg-@statusClass">@string.Format("{0:P0}", ratio)</span>
                </td>
                <td>
                    @{
                        double ratio2 = item.GetRatio();
                        if (ratio2 < 0.2)
                        {
                            <span class="badge bg-danger">@Loc.Get("Low", lang)</span>
                        }
                        else if (ratio2 < 0.5)
                        {
                            <span class="badge bg-warning">@Loc.Get("Medium", lang)</span>
                        }
                        else
                        {
                            <span class="badge bg-success">@Loc.Get("High", lang)</span>
                        }
                    }
                </td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.StationId" class="btn btn-sm btn-info">@Loc.Get("View", lang)</a>
                    <a asp-action="Edit" asp-route-id="@item.StationId" class="btn btn-sm btn-warning">@Loc.Get("Edit", lang)</a>
                    <a asp-action="Delete" asp-route-id="@item.StationId" class="btn btn-sm btn-danger">@Loc.Get("Delete", lang)</a>
                </td>
            </tr>
        }
    </tbody>
</table>
