@model SaigonRide.Models.User

@{
    ViewData["Title"] = "Delete User";
}

<h1>Delete User</h1>

<h3>Are you sure you want to delete this user?</h3>
<div>
    <dl class="row">
        <dt class="col-sm-2">Bank Number</dt>
        <dd class="col-sm-10">@Model.BankNum</dd>
        <dt class="col-sm-2">Type</dt>
        <dd class="col-sm-10">
            @if (Model is SaigonRide.Models.LocalCommuter)
            {
                <span>Local Commuter</span>
            }
            else
            {
                <span>Foreign Tourist</span>
            }
        </dd>
    </dl>

    <form asp-action="DeleteConfirmed" method="post">
        <input type="hidden" name="id" value="@Model.BankNum" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" asp-controller="Home" class="btn btn-secondary">Cancel</a>
    </form>
</div>
