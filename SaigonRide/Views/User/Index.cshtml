@model List<SaigonRide.Models.User>
@inject SaigonRide.Services.ILocalizationService Loc

@{
    ViewData["Title"] = "User Management";
    var lang = Context.Session.GetString("Lang") ?? "en";
}

<h1>@Loc.Get("UserManagement", lang)</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">@Loc.Get("AddNewUser", lang)</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>@Loc.Get("BankNumber", lang)</th>
            <th>@Loc.Get("UserType", lang)</th>
            <th>@Loc.Get("ChosenPayment", lang)</th>
            <th>@Loc.Get("TotalPaid", lang)</th>
            <th>@Loc.Get("AdditionalInfo", lang)</th>
            <th>@Loc.Get("Actions", lang)</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.BankNum</td>
                <td>
                    @if (item is SaigonRide.Models.LocalCommuter)
                    {
                        <span class="badge bg-primary">@Loc.Get("LocalCommuter", lang)</span>
                    }
                    else
                    {
                        <span class="badge bg-info">@Loc.Get("ForeignTourist", lang)</span>
                    }
                </td>
                <td>@item.ChosenPaymentCode</td>
                <td>@string.Format("{0:N0}", item.Payed) VND</td>
                <td>
                    @if (item is SaigonRide.Models.LocalCommuter local)
                    {
                        <small>MoMo: @(local.P_MoMo ? Loc.Get("Yes", lang) : Loc.Get("No", lang)) | VNPay: @(local.P_VNPay ? Loc.Get("Yes", lang) : Loc.Get("No", lang))</small>
                    }
                    else if (item is SaigonRide.Models.ForeignTourist tourist)
                    {
                        <small>@Loc.Get("Passport", lang): @tourist.Passport | ApplePay: @(tourist.P_ApplePay ? Loc.Get("Yes", lang) : Loc.Get("No", lang)) | PayPal: @(tourist.P_PayPal ? Loc.Get("Yes", lang) : Loc.Get("No", lang))</small>
                    }
                </td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.BankNum" class="btn btn-sm btn-info">@Loc.Get("View", lang)</a>
                    <a asp-action="Edit" asp-route-id="@item.BankNum" class="btn btn-sm btn-warning">@Loc.Get("Edit", lang)</a>
                    <a asp-action="Delete" asp-route-id="@item.BankNum" class="btn btn-sm btn-danger">@Loc.Get("Delete", lang)</a>
                </td>
            </tr>
        }
    </tbody>
</table>
