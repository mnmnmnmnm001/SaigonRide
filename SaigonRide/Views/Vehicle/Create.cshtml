@model SaigonRide.Models.Vehicle

@{
    ViewData["Title"] = "Create Vehicle";
}

<h1>Add New Vehicle</h1>

<div class="row">
    <div class="col-md-6 offset-md-3">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label for="Type" class="form-label">Vehicle Type</label>
                <select id="Type" name="Type" class="form-control" required>
                    <option value="">-- Select Type --</option>
                    <option value="StandardBike">Standard Bike</option>
                    <option value="EBike">E-Bike</option>
                    <option value="Scooter">E-Scooter</option>
                </select>
                <span asp-validation-for="Type" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label for="Code" class="form-label">Vehicle Code</label>
                <input type="text" id="Code" name="Code" class="form-control" required />
                <span asp-validation-for="Code" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label for="FarePerMin" class="form-label">Fare Per Minute (VND)</label>
                <input type="number" id="FarePerMin" name="FarePerMin" class="form-control" step="0.01" required />
                <small class="form-text text-muted">Standard Bike: 500, E-Bike: 1000, Scooter: 1500</small>
                <span asp-validation-for="FarePerMin" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label for="CurrentPos" class="form-label">Current Position</label>
                <input type="text" id="CurrentPos" name="CurrentPos" class="form-control" required />
                <span asp-validation-for="CurrentPos" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">Create Vehicle</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>
