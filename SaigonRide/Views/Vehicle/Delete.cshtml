@model SaigonRide.Models.Vehicle

@{
    ViewData["Title"] = "Delete Vehicle";
}

<h1>Delete Vehicle</h1>

<h3>Are you sure you want to delete this vehicle?</h3>
<div>
    <dl class="row">
        <dt class="col-sm-2">Code</dt>
        <dd class="col-sm-10">@Model.Code</dd>
        <dt class="col-sm-2">Type</dt>
        <dd class="col-sm-10">@Model.Type</dd>
        <dt class="col-sm-2">Fare Per Minute</dt>
        <dd class="col-sm-10">@string.Format("{0:N0}", Model.FarePerMin) VND</dd>
    </dl>

    <form asp-action="DeleteConfirmed" method="post">
        <input type="hidden" name="id" value="@Model.Code" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" asp-controller="Home" class="btn btn-secondary">Cancel</a>
    </form>
</div>
