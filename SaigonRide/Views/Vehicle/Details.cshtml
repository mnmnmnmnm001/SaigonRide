@model SaigonRide.Models.Vehicle
@inject SaigonRide.Services.ILocalizationService Loc

@{
    ViewData["Title"] = "Vehicle Details";
    var lang = Context.Session.GetString("Lang") ?? "en";
}

<h1>@Loc.Get("VehicleDetails", lang)</h1>

<div class="container">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card">
                <div class="card-header">
                    <h5>@Model.Type - @Model.Code</h5>
                </div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-3">@Loc.Get("Code", lang)</dt>
                        <dd class="col-sm-9">@Model.Code</dd>

                        <dt class="col-sm-3">@Loc.Get("Type", lang)</dt>
                        <dd class="col-sm-9">@Loc.Get(Model.Type ?? "", lang)</dd>

                        <dt class="col-sm-3">@Loc.Get("FarePerMin", lang)</dt>
                        <dd class="col-sm-9">@string.Format("{0:N0}", Model.FarePerMin) VND</dd>

                        <dt class="col-sm-3">@Loc.Get("CurrentPosition", lang)</dt>
                        <dd class="col-sm-9">@Loc.GetStationName(Model.CurrentPos ?? "", lang)</dd>

                        <dt class="col-sm-3">@Loc.Get("Status", lang)</dt>
                        <dd class="col-sm-9">
                            @if (Model.State == 0)
                            {
                                <span class="badge bg-success" style="font-size: 1rem;">@Loc.Get("Available", lang)</span>
                            }
                            else if (Model.State == 1)
                            {
                                <span class="badge bg-warning" style="font-size: 1rem;">@Loc.Get("InTransit", lang)</span>
                            }
                            else
                            {
                                <span class="badge bg-danger" style="font-size: 1rem;">@Loc.Get("Maintenance", lang)</span>
                            }
                        </dd>
                    </dl>
                </div>
            </div>

            <div class="mt-3">
                <a asp-action="Edit" asp-route-id="@Model.Code" class="btn btn-warning">@Loc.Get("Edit", lang)</a>
                <a asp-action="Delete" asp-route-id="@Model.Code" class="btn btn-danger">@Loc.Get("Delete", lang)</a>
                <a asp-action="Index" class="btn btn-secondary">@Loc.Get("BackToVehicles", lang)</a>
            </div>
        </div>
    </div>
</div>
