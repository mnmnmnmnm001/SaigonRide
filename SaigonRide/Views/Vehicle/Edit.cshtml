@model SaigonRide.Models.Vehicle
@inject SaigonRide.Services.ILocalizationService Loc

@{
    ViewData["Title"] = "Edit Vehicle";
    var lang = Context.Session.GetString("Lang") ?? "en";
}

<h1>@Loc.Get("EditVehicle", lang)</h1>

<div class="row">
    <div class="col-md-6 offset-md-3">
        <form asp-action="Edit" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <input type="hidden" name="Code" value="@Model.Code" />

            <div class="form-group mb-3">
                <label for="Type" class="form-label">@Loc.Get("VehicleType", lang)</label>
                <select id="Type" name="Type" class="form-control" required>
                    <option value="StandardBike" selected="@(Model.Type == "StandardBike")">@Loc.Get("StandardBike", lang)</option>
                    <option value="EBike" selected="@(Model.Type == "EBike")">@Loc.Get("EBike", lang)</option>
                    <option value="Scooter" selected="@(Model.Type == "Scooter")">@Loc.Get("Scooter", lang)</option>
                </select>
                <span asp-validation-for="Type" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label for="Code" class="form-label">@Loc.Get("VehicleCode", lang)</label>
                <input type="text" id="Code" name="Code" value="@Model.Code" class="form-control" required readonly />
                <span asp-validation-for="Code" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label for="FarePerMin" class="form-label">@Loc.Get("FarePerMin", lang) (VND)</label>
                <input type="number" id="FarePerMin" name="FarePerMin" value="@Model.FarePerMin" class="form-control" step="0.01" required />
                <span asp-validation-for="FarePerMin" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label for="State" class="form-label">@Loc.Get("Status", lang)</label>
                <select id="State" name="State" class="form-control" required>
                    <option value="0" selected="@(Model.State == 0)">@Loc.Get("Available", lang)</option>
                    <option value="1" selected="@(Model.State == 1)">@Loc.Get("InTransit", lang)</option>
                    <option value="2" selected="@(Model.State == 2)">@Loc.Get("Maintenance", lang)</option>
                </select>
                <span asp-validation-for="State" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label for="CurrentPos" class="form-label">@Loc.Get("CurrentPosition", lang)</label>
                <select id="CurrentPos" name="CurrentPos" class="form-control" required>
                    @if (ViewBag.Stations != null)
                    {
                        foreach (var station in ViewBag.Stations)
                        {
                            <option value="@station" selected="@(Model.CurrentPos == station)">@Loc.GetStationName(station, lang)</option>
                        }
                    }
                    <option value="In Transit" selected="@(Model.CurrentPos == "In Transit")">@Loc.Get("InTransit", lang)</option>
                    <option value="Maintenance" selected="@(Model.CurrentPos == "Maintenance")">@Loc.Get("Maintenance", lang)</option>
                </select>
                <span asp-validation-for="CurrentPos" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">@Loc.Get("UpdateVehicle", lang)</button>
            <a asp-action="Index" class="btn btn-secondary">@Loc.Get("Cancel", lang)</a>
        </form>
    </div>
</div>
